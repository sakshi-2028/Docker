1)Basic Docker Commands:
docker --version            # Check docker version
docker info                 # Show docker system info
docker login                # Login to Docker Hub
docker logout               # Logout

2)Image Commands:
docker images               # List images
docker pull <image>         # Download image
docker build -t name .      # Build image from Dockerfile
docker rmi <image_id>       # Remove image
docker tag src dest         # Tag image before pushing
docker push <image>         # Push image to Docker Hub

3) Container Commands
docker ps                   # Running containers
docker ps -a                # All containers
docker run image            # Run a container
docker run -d image         # Run in background
docker run -p h:c image     # Port mapping
docker run -v h:c image     # Mount volume
docker run --name myapp image   # Give container a name
docker start <container>    # Start existing container
docker stop <container>     # Stop container
docker restart <container>  # Restart
docker rm <container>       # Remove container
docker logs <container>     # Show logs
docker exec -it <container> bash # Enter the container
docker inspect <container>  # Inspect details

4)Docker Volume Commands
docker volume ls               # List volumes
docker volume create myvol     # Create volume
docker volume inspect myvol    # Inspect
docker volume rm myvol         # Remove volume

5)Docker Network Commands
docker network ls              # List networks
docker network create mynet    # Create a network
docker network inspect mynet   # Inspect
docker network rm mynet        # Remove

6)Dockerfile Commands (MOST USED)
FROM
WORKDIR
COPY
RUN
CMD
EXPOSE
ENV
ENTRYPOINT

7)Docker Compose Commands :
docker-compose up              # Start all services
docker-compose up -d           # Run in background
docker-compose down            # Stop and remove
docker-compose logs            # Show logs
docker-compose ps              # List containers
